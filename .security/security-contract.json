{
  "version": 1,
  "hooks": {
    "fuzz": {
      "argv": [
        "python3",
        "-I",
        ".security/repository_fuzz.py",
        "security-results/fuzz.json"
      ],
      "timeout_seconds": 120,
      "evidence": "security-results/fuzz.json",
      "min_cases": 64
    },
    "authenticated_negative": {
      "argv": [
        "python3",
        "-I",
        ".security/authenticated_negative.py",
        "security-results/authenticated-negative.json"
      ],
      "timeout_seconds": 120,
      "evidence": "security-results/authenticated-negative.json",
      "min_cases": 4
    }
  },
  "license_policy": {
    "allowed": [
      "0BSD",
      "Apache-2.0",
      "Apache-2.0 OR MIT",
      "BSD-2-Clause",
      "BSD-3-Clause",
      "BSL-1.0",
      "CC0-1.0",
      "ISC",
      "MIT",
      "MIT OR Apache-2.0",
      "MIT-0",
      "MPL-2.0",
      "OpenSSL",
      "Python-2.0",
      "Unicode-3.0",
      "Unlicense",
      "Zlib"
    ],
    "denied": [
      "AGPL-3.0-only",
      "AGPL-3.0-or-later",
      "GPL-3.0-only",
      "GPL-3.0-or-later"
    ],
    "allow_unknown": false
  }
}
